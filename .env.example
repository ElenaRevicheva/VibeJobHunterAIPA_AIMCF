# =============================================================================
# VIBEJOBHUNTER - COMPLETE ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your actual values
# Last updated: February 2026
# =============================================================================

# =============================================================================
# 🔑 AI API KEYS (REQUIRED)
# =============================================================================
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: fallback LLM + Telegram voice transcription (Whisper)
OPENAI_API_KEY=your_openai_api_key_here

# =============================================================================
# 📧 EMAIL SERVICE - RESEND (REQUIRED FOR FOUNDER OUTREACH)
# =============================================================================
# Get from: https://resend.com/api-keys
# Required for founder outreach emails
RESEND_API_KEY=re_your_resend_api_key_here

# Your verified sending domain email
FROM_EMAIL=Your Name <you@yourdomain.com>

# =============================================================================
# 🛡️ RATE LIMITING (PROTECTS YOUR REPUTATION)
# =============================================================================
# Conservative limits to avoid spam flagging
MAX_EMAILS_PER_DAY=10
MAX_EMAILS_PER_HOUR=3
MAX_BOUNCES_BEFORE_DISABLE=3

# =============================================================================
# 📄 RESUME & APPLICANT INFO (REQUIRED FOR ATS SUBMISSION)
# =============================================================================
# Path to your PDF resume
RESUME_PATH=autonomous_data/resumes/elena_resume.pdf

# Your application details (used to fill ATS forms)
APPLICANT_FIRST_NAME=Your
APPLICANT_LAST_NAME=Name
APPLICANT_EMAIL=you@yourdomain.com
APPLICANT_PHONE=+1-555-555-5555
APPLICANT_LINKEDIN=https://linkedin.com/in/yourprofile
APPLICANT_GITHUB=https://github.com/yourprofile
APPLICANT_PORTFOLIO=https://yoursite.com
APPLICANT_LOCATION=Your City, Country

# =============================================================================
# 🤖 ATS SUBMISSION SETTINGS
# =============================================================================
# ⚠️ START WITH TRUE, CHANGE TO FALSE ONLY AFTER TESTING
ATS_DRY_RUN=true

# Enable ATS form submission
ATS_SUBMISSION_ENABLED=true

# Enable ATS job scraping
ATS_SCRAPER_ENABLED=true

# =============================================================================
# 📊 APPLICATION THRESHOLDS (SCORING)
# =============================================================================
# Jobs scoring >= this will be auto-applied
AUTO_APPLY_THRESHOLD=60

# Jobs scoring >= this get founder outreach
OUTREACH_THRESHOLD=58

# Jobs scoring >= this go to review queue
REVIEW_THRESHOLD=55

# Max applications per day (safety cap)
MAX_DAILY_APPLICATIONS=5
MAX_TOTAL_APPLICATIONS=30

# =============================================================================
# 📬 ZOHO MAIL - EMAIL READING (REQUIRED FOR GREENHOUSE VERIFICATION)
# =============================================================================
# Some companies (like xAI) require email verification codes.
# We need to READ these codes from your Zoho inbox.
# 
# Setup:
# 1. Go to Zoho Mail → Settings → Security
# 2. Generate an "App-specific password" for VibeJobHunter
# 3. Copy the generated password here
#
# Your Zoho email (same as APPLICANT_EMAIL)
ZOHO_EMAIL=you@yourdomain.com

# App-specific password (NOT your regular Zoho password)
# Generate at: https://mail.zoho.com/zm/#settings/security/apppassword
ZOHO_APP_PASSWORD=your_zoho_app_password_here

# =============================================================================
# 🔍 EMAIL VERIFICATION (OPTIONAL BUT RECOMMENDED)
# =============================================================================
# Get from: https://hunter.io/api
# Verifies founder emails before sending (reduces bounces)
HUNTER_API_KEY=your_hunter_api_key_here

# =============================================================================
# 📱 TELEGRAM NOTIFICATIONS (OPTIONAL)
# =============================================================================
# Get from: @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# =============================================================================
# 💼 JOB PLATFORM CREDENTIALS (OPTIONAL)
# =============================================================================
LINKEDIN_EMAIL=your_linkedin_email
LINKEDIN_PASSWORD=your_linkedin_password

# =============================================================================
# 🐦 SOCIAL MEDIA (OPTIONAL - FOR TWITTER OUTREACH)
# =============================================================================
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_SECRET=your_twitter_access_secret

# =============================================================================
# 💾 DATABASE
# =============================================================================
DATABASE_URL=sqlite:///./vibejobhunter.db

# =============================================================================
# 🖥️ DASHBOARD
# =============================================================================
DASHBOARD_PORT=8000
DASHBOARD_HOST=0.0.0.0

# =============================================================================
# 📣 LINKEDIN CMO (AI Marketing Co-Founder)
# =============================================================================
MAKE_WEBHOOK_URL_LINKEDIN=https://hook.us2.make.com/your_webhook_id_here

# =============================================================================
# 🎯 PRIORITY COMPANIES (sync from OpenClaw job shortlist)
# =============================================================================
# Path to job-list-filter folder (where priority_companies_for_vibejob.json is written)
# On Oracle: /home/ubuntu/job-list-filter
OPENCLAW_JOB_LIST_PATH=/home/ubuntu/job-list-filter

# Or set exact path to the JSON file (overrides OPENCLAW_JOB_LIST_PATH):
# PRIORITY_YC_EXPORT_PATH=/home/ubuntu/job-list-filter/priority_companies_for_vibejob.json

# =============================================================================
# 🎲 DICE MCP (OPTIONAL - Tech Job Source)
# =============================================================================
# Enable Dice Model Context Protocol job search
DICE_MCP_ENABLED=true

# =============================================================================
# 📨 OUTREACH LIMITS
# =============================================================================
MAX_DAILY_OUTREACH=2

# =============================================================================
# 📈 GOOGLE ANALYTICS 4 (OPTIONAL)
# =============================================================================
GA4_PROPERTY_ID=your_ga4_property_id_here
GOOGLE_ANALYTICS_CREDENTIALS={"type":"service_account","project_id":"your_project",...}

# =============================================================================
# 📝 BLOG CROSS-POSTING — GEO+SEO ENGINE (tech milestone posts)
# =============================================================================
# Hashnode: get token at https://hashnode.com/settings/developer
# Publication ID: your blog's publication ID (from Hashnode dashboard URL)
HASHNODE_API_KEY=your_hashnode_personal_access_token
HASHNODE_PUBLICATION_ID=your_hashnode_publication_id

# dev.to: get API key at https://dev.to/settings/extensions
DEVTO_API_KEY=your_devto_api_key

# X (Twitter) tech-update polling — shared secret between dragontrade-agent and CMO AIPA
# Set the same value in both services
X_UPDATES_SECRET=your_x_updates_secret_here
